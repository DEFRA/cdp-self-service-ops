{
  "name": "cdp-self-service-ops",
  "version": "0.33.0",
  "description": "Automates create and deployment of services",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "AWS_EMF_ENVIRONMENT=Local NODE_ENV=development npm run server:watch",
    "dev:debug": "AWS_EMF_ENVIRONMENT=Local NODE_ENV=development npm run server:debug",
    "docker:dev": "npm run dev",
    "format": "prettier --write \"**/*.{cjs,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md}\"",
    "git:pre-commit-hook": "npm run security-audit && npm run format:check && npm run lint && npm test",
    "lint": "eslint --cache --cache-strategy content \"**/*.{cjs,js}\"",
    "lint:fix": "npm run lint -- --fix",
    "security-audit": "npm audit --audit-level=critical",
    "server:debug": "node --watch --inspect-brk=0.0.0.0 --env-file-if-exists=.env ./src",
    "server:watch": "node --watch --inspect=0.0.0.0 --env-file-if-exists=.env ./src",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "start": "NODE_ENV=production node . --env-file-if-exists=.env",
    "test": "TZ=UTC vitest run --coverage",
    "test:watch": "TZ=UTC vitest"
  },
  "imports": {
    "#config/*": "./src/config/*"
  },
  "license": "OGL-UK-3.0",
  "author": "Defra DDTS",
  "dependencies": {
    "@aws-sdk/client-sns": "3.1050.0",
    "@aws-sdk/credential-providers": "3.1050.0",
    "@date-fns/utc": "2.1.1",
    "@defra/cdp-validation-kit": "0.63.0",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.9",
    "@octokit/auth-app": "8.1.1",
    "@octokit/core": "7.0.6",
    "@octokit/graphql": "9.0.1",
    "@octokit/plugin-rest-endpoint-methods": "17.0.0",
    "aws4": "1.13.2",
    "convict": "6.2.5",
    "date-fns": "4.1.0",
    "eslint-plugin-package-json": "0.91.2",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "https-proxy-agent": "7.0.6",
    "joi": "18.0.2",
    "jose": "6.2.3",
    "lodash": "4.18.1",
    "mongo-locks": "3.1.2",
    "mongodb": "7.1.1",
    "pino": "10.3.1",
    "undici": "7.24.8"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/eslint-plugin": "1.6.3",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "61.5.0",
    "eslint-plugin-n": "17.23.1",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-promise": "7.2.1",
    "globals": "16.4.0",
    "husky": "9.1.7",
    "mongodb-memory-server-core": "10.4.1",
    "neostandard": "0.13.0",
    "nodemon": "3.1.11",
    "npm-run-all": "4.1.5",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.2",
    "resolve-url-loader": "5.0.0",
    "timers": "0.1.1",
    "tsx": "4.21.0",
    "vitest": "4.1.4",
    "vitest-fetch-mock": "0.4.5",
    "vitest-mongodb": "1.0.3"
  }
}
